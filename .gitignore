# ═══════════════════════════════════════════════════════════════════
#  Phish-Slayer .gitignore — Zero Secrets Policy
# ═══════════════════════════════════════════════════════════════════

# ── Dependencies ──────────────────────────────────────────────────
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Environment / Secrets (CRITICAL — never commit) ──────────────
.env
.env.*
!.env.example
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
!.env.example

# ── Next.js ───────────────────────────────────────────────────────
/.next/
/out/
next-env.d.ts

# ── Build / Production ───────────────────────────────────────────
/build
/dist
docker-compose.yml

# ── Testing ──────────────────────────────────────────────────────
/coverage

# ── Vercel ───────────────────────────────────────────────────────
.vercel

# ── OS Files ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── IDE / Editor ─────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Logs ─────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Keys / Certificates ─────────────────────────────────────────
*.pem
*.key
*.cert
*.p12

# ── TypeScript ───────────────────────────────────────────────────
*.tsbuildinfo
